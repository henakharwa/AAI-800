# ─────────────────────────────────────────────
# LCLDD Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────

# Weights & Biases API key
# Get yours at: https://wandb.ai/authorize
WANDB_API_KEY=your_wandb_api_key_here

# W&B project settings
WANDB_PROJECT=lcldd-slm-reasoning
WANDB_ENTITY=your_wandb_username_or_team

# HuggingFace token (required for gated models like Llama-3.1)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Cache directories
HF_HOME=./cache/huggingface
TRANSFORMERS_CACHE=./cache/huggingface/transformers

# Disable tokenizer parallelism warning
TOKENIZERS_PARALLELISM=false

# Disable HuggingFace symlinks warning (expected on Windows without Developer Mode)
HF_HUB_DISABLE_SYMLINKS_WARNING=1
